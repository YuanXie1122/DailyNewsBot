# Copy this file to ".env" (same folder as bot.py) and fill in real values.
# Never commit .env or paste real keys into .env.example.

# --- OpenAI API ---
OPENAI_API_KEY=sk-your-key-here
# Optional: override model if you like
OPENAI_MODEL=gpt-4.1-mini

# --- Email / SMTP settings ---
# Example below assumes Gmail with an app password; adjust as needed.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SENDER_EMAIL=your_email@gmail.com

# The address that will receive the two daily emails.
RECIPIENT_EMAIL=your_email@gmail.com

# --- Schedule (local process: python bot.py) ---
# HH:MM 24-hour, interpreted in America/New_York. Default 08:00.
# For cloud runs without keeping your PC on, use .github/workflows/daily-news.yml (GitHub Actions).
DAILY_RUN_TIME=08:00
